# ── Spendify Benchmark — GPU-enabled Docker image ────────────────────────────
# Runs classifier + categorizer benchmarks with llama-cpp-python (CUDA).
# No Streamlit, no UI — headless benchmark only.
#
# Build:  docker build -f docker/Dockerfile.benchmark -t spendify-bench .
# Run:    docker run --gpus all -v ./results:/app/results spendify-bench \
#           --model qwen2.5-3b --runs 1
#
# Azure ML: pushed to ACR, launched as ML Job with mounted input/output.

FROM nvidia/cuda:13.2.1-runtime-ubuntu22.04

# ── System deps ──────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3.11-venv python3-pip git curl \
    && rm -rf /var/lib/apt/lists/*

# Use python3.11 as default
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1

# ── uv ───────────────────────────────────────────────────────────────────────
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app

ENV UV_PYTHON_DOWNLOADS=0
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# ── Dependencies ─────────────────────────────────────────────────────────────
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev --no-install-project

# ── llama-cpp-python with CUDA acceleration ──────────────────────────────────
# The default PyPI wheel of llama-cpp-python is CPU-only. On a CUDA base
# image the model would still load but run on the container's CPU,
# wasting the GPU. Reinstall the CUDA-enabled prebuilt wheel from
# abetlen's index — same version pinned in uv.lock, just compiled with
# GGML_CUDA=on. Roughly 5-10× speedup on Ampere/Ada cards.
# When abetlen drops the cu121 wheel for a newer release, bump the
# tag here in lockstep with the uv.lock pin.
ARG LLAMA_CPP_CUDA_TAG=cu121
RUN UV_EXTRA_INDEX_URL="https://abetlen.github.io/llama-cpp-python/whl/${LLAMA_CPP_CUDA_TAG}" \
    uv pip install --upgrade --force-reinstall --no-deps "llama-cpp-python"

COPY . .
ENV PATH="/app/.venv/bin:$PATH"

# ── Models directory (mounted or downloaded at runtime) ──────────────────────
RUN mkdir -p /models /app/results

# ── Entrypoint ───────────────────────────────────────────────────────────────
# The entrypoint script handles: model download, classifier bench, categorizer bench
COPY docker/benchmark_entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
